# アクセスパスワード（設定しない場合は認証スキップ）
ACCESS_PASSWORD=yourpassword

# 認証トークン署名用シークレット（設定しない場合は起動ごとにランダム生成）
AUTH_SECRET=your-random-secret-here

# tmuxのパス（デフォルト: /opt/homebrew/bin/tmux）
# TMUX_BIN=/usr/bin/tmux

# ポート番号（デフォルト: 3001）
# PORT=3001

# 自動起動セッション（デフォルト: shell:shell,claude:claude）
# AUTO_SESSIONS=shell:shell,claude:claude
